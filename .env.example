# ──────────────────────────────────────────────
# WatchPost Environment Configuration
# Copy to .env and fill in your values
# ──────────────────────────────────────────────

# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://watchpost:watchpost@postgres:5432/watchpost

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── MinIO (S3-compatible object storage) ──────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=watchpost
MINIO_SECRET_KEY=changeme-minio-secret
MINIO_BUCKET=watchpost

# ── Authentication ────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=changeme-generate-a-real-secret

# ── UniFi Protect ─────────────────────────────
PROTECT_URL=https://192.168.1.1
PROTECT_USERNAME=watchpost-service
PROTECT_PASSWORD=changeme-protect-password

# ── Face Sidecar ──────────────────────────────
FACE_SIDECAR_URL=http://face-sidecar:5500

# ── Face Matching ─────────────────────────────
# Cosine distance threshold (lower = stricter)
MATCH_THRESHOLD=0.4

# ── Alert Routing (all optional) ──────────────

# Webhook: POST JSON payload to this URL on alerts
ALERT_WEBHOOK_URL=

# SMS via Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Email via SendGrid
SENDGRID_API_KEY=

# ── Feature Flags ─────────────────────────────
# License plate recognition (requires LPR-capable cameras)
FEATURE_LPR=false
# Multi-site management
FEATURE_MULTISITE=false

# ── General ───────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
PORT=3001
WEB_PORT=3000
